http://qa.qabu.net {
	handle_path /facebook* {
		reverse_proxy facebook-dispatcher:3210
	}

	handle_path /auth/* {
		reverse_proxy auth:3456
	}

	handle_path /onboarding* {
		forward_auth auth:3456 {
			uri /verify
			copy_headers X-Auth-Email X-Auth-Name
			@unauth status 401
			handle_response @unauth {
				redir http://qa.qabu.net:8080/auth/login?return_to={scheme}://{hostport}/onboarding{uri} 302
			}
		}
		reverse_proxy client-onboarding:4321
	}

	handle /privacy* {
		root * /srv
		try_files {path} {path}/index.html
		file_server
	}

	handle /terms* {
		root * /srv
		try_files {path} {path}/index.html
		file_server
	}

	handle {
		reverse_proxy landing-page:80
	}
}

# Unmatched subdomains → "claim this subdomain" pitch page (see prod Caddyfile).
# (*.qa.qabu.co.il previews the Hebrew version; needs the wildcard → 127.0.0.1
# record in the qabu.co.il zone, same as the qabu.net one.)
http://*.qa.qabu.net, http://*.qa.qabu.co.il {
	handle /favicon.ico {
		root * /srv
		file_server
	}

	handle {
		rewrite * /index.html
		root * /srv/claim
		file_server
	}
}
