qabu.net {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	handle /facebook-page-signup* {
		forward_auth auth:3456 {
			uri /verify
			@unauth status 401
			handle_response @unauth {
				redir https://qabu.net/auth/login?return_to={scheme}://{host}/facebook-page-signup 302
			}
		}
		reverse_proxy facebook-signup:8558
	}

	handle_path /facebook* {
		reverse_proxy facebook-dispatcher:3210
	}

	handle_path /auth/* {
		reverse_proxy auth:3456
	}

	handle_path /onboarding* {
		forward_auth auth:3456 {
			uri /verify
			copy_headers X-Auth-Email X-Auth-Name
			@unauth status 401
			handle_response @unauth {
				redir https://qabu.net/auth/login?return_to={scheme}://{host}/onboarding{uri} 302
			}
		}
		reverse_proxy client-onboarding:4321
	}

	handle /favicon.ico {
		root * /srv
		file_server
	}

	handle /logo_*.svg {
		root * /srv
		file_server
	}

	handle /privacy* {
		root * /srv
		try_files {path} {path}/index.html
		file_server
	}

	handle /terms* {
		root * /srv
		try_files {path} {path}/index.html
		file_server
	}

	handle {
		reverse_proxy landing-page:80
	}
}

qabu.co.il {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	reverse_proxy landing-page-hebrew:80
}

# Unmatched subdomains: wildcard DNS points here (client subdomains have
# more-specific records that win). Serves the "claim this subdomain" pitch
# page, which language-switches on hostname client-side.
*.qabu.net, *.qabu.co.il {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	handle /favicon.ico {
		root * /srv
		file_server
	}

	handle {
		rewrite * /index.html
		root * /srv/claim
		file_server
	}
}
