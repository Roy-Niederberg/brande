qabu.net {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	handle_path /facebook* {
		reverse_proxy facebook-dispatcher:3210
	}

	handle_path /auth/* {
		reverse_proxy auth:3456
	}

	handle_path /onboarding* {
		forward_auth auth:3456 {
			uri /verify
			copy_headers X-Auth-Email X-Auth-Name
			@unauth status 401
			handle_response @unauth {
				redir https://qabu.net/auth/login?return_to={scheme}://{host}/onboarding{uri} 302
			}
		}
		reverse_proxy client-onboarding:8559
	}

	handle {
		root * /srv
		try_files {path} {path}/index.html
		file_server
	}
}

*.qabu.net {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	reverse_proxy {labels.2}-site-1:80

	handle_errors {
		header Content-Type text/html
		respond <<HTML
			<!DOCTYPE html>
			<html><head><title>404</title></head>
			<body style="font-family:sans-serif;display:flex;justify-content:center;align-items:center;height:100vh;margin:0">
			<h1>404 - Service not found</h1>
			<p><h2>qabu.net</h2></p>
			</body></html>
			HTML 404
	}
}
