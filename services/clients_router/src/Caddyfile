# Client VM entry point for *.qabu.net (full: admin + Facebook + public) and
# *.qabu.co.il (public chat only — see the second block).
# Terminates TLS and routes to per-client services-routers ({subdomain}-services-router-1:80) after auth checks.
*.qabu.net {
	# Wildcard TLS cert via Cloudflare DNS challenge
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	# Facebook webhook forwarding from the dispatcher (main server).
	# Only the dispatcher knows FB_DISPATCHER_SECRET, so this path is
	# never reachable by external actors directly.
	@facebook_auth {
		path /facebook-*
		header X-Dispatcher-Secret {env.FB_DISPATCHER_SECRET}
	}
	handle @facebook_auth {
		reverse_proxy {labels.2}-services-router-1:80
	}
	@facebook_noauth {
		path /facebook-*
	}
	respond @facebook_noauth 403

	# Authed prefix: any /bab/{service}/* is verified via the auth-verifier
	# sidecar (JWT), with redirect to Google login on 401. Forwards
	# X-Auth-Email/X-Auth-Name to the services-router, which routes
	# /bab/{service}/* → {service}:4322 (authed services listen on 4322 —
	# 4321 is reachable via the public bare rule, so it must never carry
	# authed-only surfaces).
	@bab path /bab/*
	handle @bab {
		forward_auth auth-verifier:3456 {
			uri /
			copy_headers X-Auth-Email X-Auth-Name
			@unauth status 401
			handle_response @unauth {
				redir https://qabu.net/auth/login?return_to={scheme}://{host}{uri} 302
			}
		}
		reverse_proxy {labels.2}-services-router-1:80
	}

	# Back-compat: the admin used to live at /admin/*; bookmarks 301 to
	# /bab/admin/* ({uri} keeps the original /admin prefix + query).
	redir /admin/* /bab{uri} 301
	redir /admin /bab/admin/ 301

	# Provisioner: scaffolds new client directories
	@provision path /scaffold
	handle @provision {
		reverse_proxy provisioner:4321
	}

	# All other traffic → per-client services-router (subdomain derived from {labels.2})
	reverse_proxy {labels.2}-services-router-1:80
	handle_errors {
		header Content-Type text/html
		header X-Qabu not-found
		respond <<HTML
			<!DOCTYPE html>
			<html><head><title>404</title></head>
			<body style="font-family:sans-serif;display:flex;justify-content:center;align-items:center;height:100vh;margin:0">
			<h1>404 - Service not found</h1>
			<h2>qabu.net</h2>
			</body></html>
			HTML 404
	}
}

# Hebrew-branded public mirror of the client sites on *.qabu.co.il.
# Serves the SAME per-client backends as *.qabu.net, but the subdomain is one
# label deeper ({labels.3}: il=0, co=1, qabu=2, eintal=3).
# Admin + Facebook intentionally stay on *.qabu.net: the JWT cookie is scoped to
# .qabu.net and can't cross to .co.il, so /bab/* (authed services) is redirected
# there and /facebook-* is closed (the dispatcher only ever targets *.qabu.net
# hosts).
*.qabu.co.il {
	# Wildcard TLS cert via Cloudflare DNS challenge (issued on first request).
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	# Authed routes can't authenticate here (cookie is .qabu.net) — bounce to
	# the .net domain, preserving path + query. /admin* is kept alongside
	# /bab* so old bookmarks chain through the .net 301 to /bab/admin/.
	@authed path /bab* /admin*
	redir @authed https://{labels.3}.qabu.net{uri} 302

	# Facebook webhooks are dispatched to *.qabu.net only; close the path here so
	# the per-client FB handlers aren't reachable unauthenticated via .co.il.
	@facebook path /facebook-*
	respond @facebook 403

	# Public chat → same per-client services-router as qabu.net.
	reverse_proxy {labels.3}-services-router-1:80
	handle_errors {
		header Content-Type text/html
		header X-Qabu not-found
		respond <<HTML
			<!DOCTYPE html>
			<html><head><title>404</title></head>
			<body style="font-family:sans-serif;display:flex;justify-content:center;align-items:center;height:100vh;margin:0">
			<h1>404 - Service not found</h1>
			<h2>qabu.co.il</h2>
			</body></html>
			HTML 404
	}
}
