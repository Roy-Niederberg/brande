# Client VM entry point for all *.qabu.net traffic.
# Terminates TLS and routes to per-client gateways ({subdomain}-gateway-1:80) after auth checks.
*.qabu.net {
	# Wildcard TLS cert via Cloudflare DNS challenge
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	# Facebook webhook forwarding from the dispatcher (main server).
	# Only the dispatcher knows FB_DISPATCHER_SECRET, so this path is
	# never reachable by external actors directly.
	@facebook_auth {
		path /facebook-*
		header X-Dispatcher-Secret {env.FB_DISPATCHER_SECRET}
	}
	handle @facebook_auth {
		reverse_proxy {labels.2}-gateway-1:80
	}
	@facebook_noauth {
		path /facebook-*
	}
	respond @facebook_noauth 403

	# Admin: verify JWT via auth-verifier sidecar; redirect to Google
	# login on 401. Forwards X-Auth-Email/X-Auth-Name to the gateway.
	@admin path /admin/*
	handle @admin {
		forward_auth auth-verifier:3456 {
			uri /
			copy_headers X-Auth-Email X-Auth-Name
			@unauth status 401
			handle_response @unauth {
				redir https://qabu.net/auth/login?return_to={scheme}://{host}{uri} 302
			}
		}
		reverse_proxy {labels.2}-gateway-1:80
	}

	# All other traffic → per-client gateway (subdomain derived from {labels.2})
	reverse_proxy {labels.2}-gateway-1:80
	handle_errors {
		header Content-Type text/html
		respond <<HTML
			<!DOCTYPE html>
			<html><head><title>404</title></head>
			<body style="font-family:sans-serif;display:flex;justify-content:center;align-items:center;height:100vh;margin:0">
			<h1>404 - Service not found</h1>
			<h2>qabu.net</h2>
			</body></html>
			HTML 404
	}
}
